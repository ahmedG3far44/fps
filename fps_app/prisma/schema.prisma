generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  USER
  ADMIN
}

enum StoreType {
  OFFICIAL
  AUTHORIZED_RESELLER
}

enum Resolution {
  P720
  P1080
  P1440
  P4K
}

enum Quality {
  ULTRA
  HIGH
  MEDIUM
  LOW
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?
  role           UserRole  @default(USER)
  countryId      String?
  currencyId     String?
  preferredResolution Resolution?
  theme          String    @default("dark")
  language       String    @default("en")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  hardware       Hardware?
  aiConversations AIConversation[]
  searchHistory  SearchHistory[]
  country        Country?  @relation(fields: [countryId], references: [id])
  currency       Currency? @relation(fields: [currencyId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Game {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  coverUrl    String?
  isFree      Boolean  @default(false)
  releaseDate DateTime?
  engine      String?
  igdbId      Int?     @unique
  rawgId      Int?
  itadPlainId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  developerId String?
  publisherId String?

  developer    Developer?        @relation(fields: [developerId], references: [id])
  publisher    Publisher?        @relation(fields: [publisherId], references: [id])
  genres       GameGenre[]
  benchmarks   Benchmark[]
  requirements Requirement[]
  recommendations Recommendation[]
  prices       GameStorePrice[]
}

model Developer {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  games Game[]
}

model Publisher {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  games Game[]
}

model Genre {
  id    String     @id @default(cuid())
  name  String     @unique
  slug  String     @unique
  games GameGenre[]
}

model GameGenre {
  gameId  String
  genreId String
  game    Game  @relation(fields: [gameId], references: [id], onDelete: Cascade)
  genre   Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([gameId, genreId])
}

model Hardware {
  id            String  @id @default(cuid())
  userId        String  @unique
  cpu           String?
  gpu           String?
  ramGB         Int?
  storageType   String?
  storageGB     Int?
  motherboard   String?
  monitorResolution String?
  os            String?
  rawJson       String?
  lastSyncedAt  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Benchmark {
  id          String     @id @default(cuid())
  gameId      String
  resolution  Resolution
  quality     Quality
  fps         Int
  source      String?
  verified    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, resolution, quality])
}

model Requirement {
  id         String  @id @default(cuid())
  gameId     String
  type       String
  os         String?
  cpu        String?
  gpu        String?
  ramGB      Int?
  storageGB  Int?
  directX    String?
  notes      String?

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
}

model Recommendation {
  id         String  @id @default(cuid())
  gameId     String
  title      String
  description String?
  type       String
  priority   Int     @default(0)
  createdAt  DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
}

model Country {
  id             String          @id @default(cuid())
  code           String          @unique
  name           String
  currencyId     String?
  currency       Currency?       @relation(fields: [currencyId], references: [id])
  users          User[]
  hardwarePrices HardwarePrice[]
}

model Currency {
  id             String          @id @default(cuid())
  code           String          @unique
  name           String
  symbol         String
  countries      Country[]
  users          User[]
  hardwarePrices HardwarePrice[]
}

model HardwarePrice {
  id          String   @id @default(cuid())
  hardwareName String
  hardwareType String
  price       Float
  store       String
  currencyId  String
  countryId   String
  url         String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  country  Country  @relation(fields: [countryId], references: [id])
  currency Currency @relation(fields: [currencyId], references: [id])

  @@unique([hardwareName, hardwareType, store, countryId, currencyId])
}

model AIConversation {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  model     String?
  tokens    Int?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Store {
  id    String    @id @default(cuid())
  name  String
  slug  String    @unique
  logoUrl String?
  type  StoreType
  prices GameStorePrice[]
}

model GameStorePrice {
  id            String   @id @default(cuid())
  gameId        String
  storeId       String
  countryCode   String
  currency      String
  currentPrice  Float
  originalPrice Float?
  discount      Int?
  buyUrl        String
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  game  Game  @relation(fields: [gameId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@index([countryCode])
}

model SearchHistory {
  id        String   @id @default(cuid())
  userId    String
  query     String
  type      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
